{
  "version": 2,
  "builds": [
    {
      "src": "src/server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "src/client/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/src/server/server.js"
    },
    {
      "src": "/css/(.*)",
      "dest": "/src/client/public/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/src/client/public/js/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/src/client/public/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/src/client/public/index.html"
    }
  ]
}
