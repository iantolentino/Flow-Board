# Application Environment
NODE_ENV=development
PORT=3000

# Security - Generate these with:
# JWT_SECRET: openssl rand -base64 32
# SESSION_SECRET: openssl rand -base64 32
# ENCRYPTION_KEY: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here-minimum-32-characters
SESSION_SECRET=your-session-secret-here-minimum-32-characters
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Database
DATABASE_URL=postgresql://myboard:myboard123@localhost:5432/myboard
DB_PASSWORD=myboard123

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Feature Flags
ENABLE_GUEST_MODE=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080